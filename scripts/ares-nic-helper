#!/usr/bin/env bash
#
# ares-nic-helper — the *only* privileged piece of the SDR-as-NIC feature.
#
# Creating a kernel TAP/TUN interface needs CAP_NET_ADMIN, but we don't want to
# run the whole Ares backend as root. So install.sh drops this script in
# /usr/local/sbin (root-owned, 0755) and adds a NOPASSWD sudoers rule scoped to
# *exactly this file*; the unprivileged backend calls it via `sudo -n`. It
# creates a **persistent, caller-owned** TAP/TUN — once that exists, the backend
# attaches to it (TUNSETIFF) and does all packet I/O + the modem DSP with no
# privilege at all.
#
# Because the sudoers grant runs this as root, every argument is STRICTLY
# validated and the script only ever touches `ares-nic*` interfaces and only ever
# exec's `ip`. It never takes a free-form command.
#
set -euo pipefail

die() { echo "ares-nic-helper: $*" >&2; exit 2; }

valid_if()   { [[ "$1" =~ ^ares-nic[0-9]{1,3}$ ]] || die "bad interface name: $1"; }
valid_mode() { [[ "$1" == tap || "$1" == tun ]]   || die "bad mode: $1"; }
valid_uid()  { [[ "$1" =~ ^[0-9]{1,7}$ ]]         || die "bad uid: $1"; }
valid_mtu()  { [[ "$1" =~ ^[0-9]{2,5}$ ]] && [ "$1" -ge 256 ] && [ "$1" -le 65535 ] || die "bad mtu: $1"; }
valid_cidr() { [[ "$1" =~ ^[0-9a-fA-F:.]+/[0-9]{1,3}$ ]] || die "bad cidr: $1"; }

IP="$(command -v ip || true)"; [ -x "${IP:-}" ] || IP="/sbin/ip"
[ -x "$IP" ] || die "ip(8) not found"

cmd="${1:-}"; shift || true
case "$cmd" in
  check)
    exit 0 ;;                                  # proves sudo + helper are wired
  up)
    mode="${1:?mode}"; ifn="${2:?ifname}"; uid="${3:?uid}"; mtu="${4:?mtu}"; cidr="${5:-}"
    valid_mode "$mode"; valid_if "$ifn"; valid_uid "$uid"; valid_mtu "$mtu"
    # idempotent create — already-exists is fine (we re-assert config below)
    "$IP" tuntap add dev "$ifn" mode "$mode" user "$uid" 2>/dev/null || true
    "$IP" link set dev "$ifn" mtu "$mtu"
    if [ -n "$cidr" ]; then valid_cidr "$cidr"; "$IP" addr replace "$cidr" dev "$ifn"; fi
    "$IP" link set dev "$ifn" up
    echo "$ifn" ;;
  down)
    ifn="${1:?ifname}"; valid_if "$ifn"
    "$IP" link set dev "$ifn" down 2>/dev/null || true
    "$IP" tuntap del dev "$ifn" mode tap 2>/dev/null \
      || "$IP" tuntap del dev "$ifn" mode tun 2>/dev/null || true ;;
  *)
    die "unknown command: ${cmd:-<none>} (expected check|up|down)" ;;
esac
