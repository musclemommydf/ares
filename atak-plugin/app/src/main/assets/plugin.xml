<?xml version="1.0" encoding="utf-8"?>
<!--
  ARES-ATAK plugin descriptor. ATAK's AtakPluginRegistry reads this on plugin
  load and instantiates the IPlugin singleton declared below. AresPlugin is
  given an IServiceController + plugin Context by ATAK; its constructor wires
  the toolbar tool (opens the dropdown) and the map component (registers the
  dropdown receiver, overlays, and CoT listeners).
-->
<plugin>
    <extension singleton="true"
               impl="com.ares.atak.plugin.AresPlugin"
               type="gov.tak.api.plugin.IPlugin"/>
</plugin>
