{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ares",
  "version": "5.2.0",
  "identifier": "com.ares.app",
  "build": {
    "frontendDist": "dist-shell"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "splash",
        "title": "Ares",
        "width": 1440,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "center": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["appimage", "deb", "nsis", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Utility",
    "shortDescription": "RF propagation & geolocation platform",
    "longDescription": "Ares — air-gappable RF propagation, geolocation and passive-observation platform."
  }
}
